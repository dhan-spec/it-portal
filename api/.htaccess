<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /api/
    SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
    RewriteCond %{HTTP:Authorization} ^(.*)
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%1]
    RewriteRule ^login$ login.php [QSA,L]
    RewriteRule ^assets$ assets.php [QSA,L]
    RewriteRule ^assets/(.*)$ asset_detail.php?tag=$1 [QSA,L]
    RewriteRule ^logs$ logs.php [QSA,L]
    RewriteRule ^reports$ reports.php [QSA,L]
    RewriteRule ^report_issue$ report_issue.php [QSA,L]
    RewriteRule ^accomplishments$ accomplishments.php [QSA,L]
</IfModule>
